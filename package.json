{
  "name": "ai-bridge",
  "version": "0.1.0",
  "description": "Standalone bridge from the Claude Code harness to the GitHub Copilot HTTP API",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ai-bridge": "dist/index.js"
  },
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@hono/node-server": "^1.17.1",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.8.9",
    "impit": "^0.14.2",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
